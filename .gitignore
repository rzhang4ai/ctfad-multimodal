# ============================================================
# .gitignore — ctfad-pipeline
# 原则：代码和配置入库，数据和本机路径永不入库
# ============================================================

# ----------------------------------------------------------
# 数据文件（绝对不入库）
# ----------------------------------------------------------
*.jsonl
*.jsonl.bak

# 图片文件
*.jpg
*.jpeg
*.png
*.webp
*.tiff
*.tif
*.bmp
*.gif

# PDF 原始扫描件
*.pdf

# 3D 模型文件
*.glb
*.gltf
*.obj
*.mtl
*.stl
*.ply
*.fbx
*.usdz
*.blend
*.blend1

# 数据目录（如果意外在项目目录下创建了 data/ 之类的）
data/
datasets/
raw/
outputs/

# ----------------------------------------------------------
# 本机路径配置（含绝对路径，不同机器不同）
# ----------------------------------------------------------
config/path_config.yaml
config/path_config.yml
.env
.env.*

# ----------------------------------------------------------
# Python 环境
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# ----------------------------------------------------------
# macOS 系统文件
# ----------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# ----------------------------------------------------------
# Jupyter Notebook
# ----------------------------------------------------------
.ipynb_checkpoints/
*.ipynb  # 如需保留 notebook 请手动注释此行

# ----------------------------------------------------------
# 编辑器
# ----------------------------------------------------------
.cursor/
.vscode/
*.swp
*.swo

# ----------------------------------------------------------
# 日志与临时文件
# ----------------------------------------------------------
*.log
logs/
tmp/
temp/

# ----------------------------------------------------------
# Dashboard（项目细节暂不公开，等准备好分享时再解除）
# ----------------------------------------------------------
# index.html 可入库（GitHub Pages 用），但数据和说明暂时私有
dashboard/data.json
dashboard/README.md
